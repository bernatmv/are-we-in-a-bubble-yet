---
interface Props {
  id: string;
  score: number;
  label: string;
  name?: string;
  compact?: boolean;
}

const { score, label, name, compact = false } = Astro.props;
const safeScore = Math.max(0, Math.min(100, score));
const needleAngle = -180 + safeScore * 1.8;
const gaugeColor = safeScore >= 75
  ? '#ff4d2e'
  : safeScore >= 60
    ? '#df7b17'
    : safeScore >= 45
      ? '#d7a329'
      : safeScore >= 30
        ? '#99a04c'
        : '#718575';
---

<div class:list={['speed-gauge', compact && 'compact']} role="img" aria-label={`${name ?? label}: ${safeScore} / 100`}>
  <strong class="gauge-score">{safeScore}</strong>
  <svg viewBox="0 0 120 82" aria-hidden="true">
    <path class="gauge-base" d="M12 58 A48 48 0 0 1 108 58" />
    <path
      class="gauge-color"
      d="M12 58 A48 48 0 0 1 108 58"
      pathLength="100"
      stroke={gaugeColor}
      stroke-dasharray={`${safeScore} 100`}
    />
    <line class="needle" x1="60" y1="58" x2="95" y2="58" transform={`rotate(${needleAngle} 60 58)`} />
    <circle class="pin" cx="60" cy="58" r="5" />
    <circle class="pin-core" cx="60" cy="58" r="1.8" fill={gaugeColor} />
  </svg>
  {name && <span class="gauge-name">{name}</span>}
</div>

<style>
  .speed-gauge { position:relative; width:190px; padding-top:26px; color:var(--ink); }
  .gauge-score { position:absolute; top:0; right:0; color:var(--risk); font:500 21px/1 'DM Mono',monospace; letter-spacing:-.06em; }
  svg { display:block; width:100%; overflow:visible; }
  .gauge-base,.gauge-color { fill:none; stroke-linecap:round; }
  .gauge-base { stroke:#d8d6cd; stroke-width:10; }
  .gauge-color { stroke-width:7.5; animation:fill-gauge .9s .1s both cubic-bezier(.2,.8,.2,1); }
  .needle { stroke:var(--ink); stroke-width:2.3; stroke-linecap:round; filter:drop-shadow(0 1px 1px rgba(0,0,0,.15)); transition:transform .8s cubic-bezier(.2,.8,.2,1); }
  .pin { fill:var(--ink); }
  .gauge-name { display:block; margin-top:7px; color:var(--muted); font:500 9px/1.4 'DM Mono',monospace; letter-spacing:.035em; text-transform:uppercase; }
  .compact { width:100%; min-width:58px; padding-top:21px; }
  .compact .gauge-score { font-size:18px; }
  .compact .gauge-name { min-height:26px; font-size:8.5px; }
  @keyframes fill-gauge { from { stroke-dasharray:0 100; } }
  @media (prefers-reduced-motion:reduce) { .gauge-color { animation:none; } }
  @media (max-width:800px) {
    .speed-gauge:not(.compact) { width:150px; padding-top:28px; }
    .speed-gauge:not(.compact) .gauge-score { font-size:22px; }
    .compact .gauge-name { font-size:8.5px; }
  }
</style>
