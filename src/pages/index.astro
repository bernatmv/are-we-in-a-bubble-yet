---
import data from '../data/indicators.json';

const colors = { Extreme: '#ff4d2e', Elevated: '#d7a329', Complacent: '#df7b17', Neutral: '#526656' };

function chartPoints(history: (number | number[])[][]) {
  const values = history.map((point) => Number(point[1]));
  const min = Math.min(...values);
  const max = Math.max(...values);
  return values.map((value, index) => {
    const x = (index / (values.length - 1)) * 100;
    const y = 36 - ((value - min) / Math.max(max - min, 1)) * 30;
    return `${x.toFixed(1)},${y.toFixed(1)}`;
  }).join(' ');
}

const updated = new Intl.DateTimeFormat('en-US', { dateStyle: 'medium', timeZone: 'UTC' }).format(new Date(data.updatedAt));
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content="A plain-English dashboard of reliable US stock market bubble indicators, updated daily." />
    <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><circle cx=%2250%22 cy=%2250%22 r=%2238%22 fill=%22%23ff4d2e%22/></svg>" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@300;400;500&family=Instrument+Serif:ital@0;1&family=Manrope:wght@400;500;600&display=swap" rel="stylesheet" />
    <title>Are we in a bubble yet?</title>
  </head>
  <body>
    <header class="site-header wrap">
      <a class="wordmark" href="/" aria-label="Are we in a bubble yet? home">
        <span class="mark"></span>
        ARE WE IN A BUBBLE YET?
      </a>
      <div class="freshness"><span></span> DATA CHECKED DAILY · {updated.toUpperCase()}</div>
    </header>

    <main>
      <section class="hero wrap" aria-labelledby="verdict-title">
        <div class="hero-copy">
          <p class="kicker">THE SHORT ANSWER</p>
          <h1 id="verdict-title">{data.verdict}<i>.</i></h1>
          <p class="hero-summary">{data.summary}</p>
        </div>
        <div class="score-panel" aria-label={`Bubble pressure score: ${data.score} out of 100`}>
          <div class="score-top">
            <span>COMPOSITE PRESSURE</span>
            <span>{data.score} / 100</span>
          </div>
          <div class="score-track"><span style={`width:${data.score}%`}></span></div>
          <div class="score-labels"><span>COOL</span><span>STRETCHED</span><span>BUBBLE</span></div>
          <p>Four of five signals are elevated. Valuation and leverage account for 80% of the score.</p>
        </div>
        <div class="scroll-cue" aria-hidden="true">↓ <span>READ THE EVIDENCE</span></div>
      </section>

      <section class="evidence wrap" aria-labelledby="evidence-title">
        <div class="section-heading">
          <div>
            <p class="kicker">THE EVIDENCE</p>
            <h2 id="evidence-title">Five signals.<br /><em>One clear read.</em></h2>
          </div>
          <p>No single metric can call a market top. We combine slow-moving valuation and leverage data with faster credit and sentiment signals.</p>
        </div>

        <div class="cards">
          {data.indicators.map((indicator, index) => (
            <article class:list={['indicator', index === 0 && 'featured']} style={`--signal:${colors[indicator.status as keyof typeof colors] ?? '#526656'}`}>
              <div class="card-header">
                <div>
                  <p class="eyebrow">{String(index + 1).padStart(2, '0')} / {indicator.eyebrow}</p>
                  <h3>{indicator.name}</h3>
                </div>
                <span class="status"><i></i>{indicator.status}</span>
              </div>

              <div class="metric-row">
                <div>
                  <strong>{indicator.displayValue}</strong>
                  <span>{indicator.change}</span>
                </div>
                <div class="gauge" aria-label={`${indicator.name} risk score ${indicator.score} out of 100`}>
                  <span class="gauge-label">RISK {indicator.score}</span>
                  <div class="gauge-track"><i style={`left:${indicator.score}%`}></i></div>
                  <div class="gauge-ends"><span>LOW</span><span>HIGH</span></div>
                </div>
              </div>

              <div class="chart-wrap">
                <svg class="chart" viewBox="0 0 100 40" preserveAspectRatio="none" role="img" aria-label={`${indicator.name} historical trend`}>
                  <line x1="0" y1="36" x2="100" y2="36" />
                  <line x1="0" y1="21" x2="100" y2="21" />
                  <line x1="0" y1="6" x2="100" y2="6" />
                  <polygon points={`0,36 ${chartPoints(indicator.history)} 100,36`} />
                  <polyline points={chartPoints(indicator.history)} />
                  <circle cx="100" cy={chartPoints(indicator.history).split(' ').at(-1)?.split(',')[1]} r="1.7" />
                </svg>
                <div class="chart-years"><span>{indicator.history[0][0]}</span><span>HISTORICAL TREND</span><span>{indicator.history.at(-1)?.[0]}</span></div>
              </div>

              <p class="description">{indicator.description}</p>
              <div class="card-footer">
                <span>{indicator.threshold}</span>
                <a href={indicator.sourceUrl} target="_blank" rel="noreferrer">{indicator.source} ↗</a>
              </div>
              <span class="as-of">AS OF {indicator.asOf.toUpperCase()}</span>
            </article>
          ))}
        </div>
      </section>

      <section class="method wrap" aria-labelledby="method-title">
        <p class="kicker">HOW TO READ THIS</p>
        <div>
          <h2 id="method-title">A temperature check,<br /><em>not a crystal ball.</em></h2>
          <div class="method-copy">
            <p>This score measures how closely today resembles historically overheated US equity markets. It does not predict when prices will turn—or whether they must.</p>
            <p>Each indicator is normalized from 0–100 against transparent thresholds, then weighted toward fundamentals: valuation 55%, leverage 25%, credit 12%, sentiment 8%.</p>
          </div>
        </div>
      </section>
    </main>

    <footer class="wrap">
      <a class="wordmark" href="/"><span class="mark"></span> ARE WE IN A BUBBLE YET?</a>
      <p>Built from public data. Not investment advice.</p>
      <a href="#method-title">METHODOLOGY & DATA ↑</a>
    </footer>
  </body>
</html>

<style is:global>
  :root { --paper:#f0eee7; --ink:#151711; --muted:#6d7067; --line:#c9c7bd; --risk:#ff4d2e; --green:#526656; }
  * { box-sizing:border-box; }
  html { scroll-behavior:smooth; }
  body { margin:0; color:var(--ink); background:var(--paper); font-family:'Manrope', sans-serif; font-size:15px; }
  body::before { content:''; position:fixed; inset:0; pointer-events:none; opacity:.26; background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 180 180' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='.9' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='.18'/%3E%3C/svg%3E"); z-index:10; mix-blend-mode:multiply; }
  a { color:inherit; }
  .wrap { width:min(1320px, calc(100% - 64px)); margin-inline:auto; }
  .site-header { height:78px; display:flex; align-items:center; justify-content:space-between; border-bottom:1px solid var(--line); }
  .wordmark { display:flex; align-items:center; gap:11px; font-family:'DM Mono', monospace; font-size:12px; font-weight:500; letter-spacing:.08em; text-decoration:none; }
  .mark { width:12px; height:12px; border-radius:50%; display:inline-block; background:var(--risk); box-shadow:0 0 0 4px rgba(255,77,46,.14); }
  .freshness { display:flex; align-items:center; gap:9px; font-family:'DM Mono', monospace; font-size:10px; letter-spacing:.1em; color:var(--muted); }
  .freshness span { width:6px; height:6px; background:#5f8b66; border-radius:50%; animation:pulse 2.5s infinite; }
  .hero { min-height:calc(100vh - 78px); position:relative; display:grid; grid-template-columns:1.35fr .65fr; gap:9vw; align-items:center; padding-block:80px 110px; }
  .kicker,.eyebrow { font-family:'DM Mono', monospace; font-size:10px; letter-spacing:.15em; font-weight:500; }
  .kicker::before { content:'— '; color:var(--risk); }
  h1 { font-family:'Instrument Serif', serif; font-size:clamp(150px, 24vw, 360px); font-weight:400; line-height:.68; letter-spacing:-.07em; margin:34px 0 54px -12px; }
  h1 i { color:var(--risk); font-style:normal; }
  .hero-summary { max-width:610px; margin:0; font-size:clamp(20px, 2vw, 29px); line-height:1.42; letter-spacing:-.035em; }
  .score-panel { align-self:center; border-top:1px solid var(--ink); border-bottom:1px solid var(--line); padding:18px 0 24px; }
  .score-top,.score-labels,.gauge-ends { display:flex; justify-content:space-between; font:500 10px 'DM Mono', monospace; letter-spacing:.08em; }
  .score-top span:last-child { color:var(--risk); }
  .score-track { height:8px; margin:18px 0 8px; background:#dad8cf; overflow:hidden; }
  .score-track span { display:block; height:100%; background:var(--risk); transform-origin:left; animation:grow 1.2s .25s both cubic-bezier(.2,.8,.2,1); }
  .score-labels { color:var(--muted); font-size:8px; }
  .score-panel p { margin:28px 0 0; max-width:380px; color:var(--muted); font-size:13px; line-height:1.6; }
  .scroll-cue { position:absolute; bottom:26px; left:0; display:flex; gap:12px; align-items:center; color:var(--risk); font:500 9px 'DM Mono', monospace; letter-spacing:.12em; }
  .evidence { padding-block:120px; border-top:1px solid var(--ink); }
  .section-heading { display:grid; grid-template-columns:1fr 1fr; gap:40px; align-items:end; margin-bottom:70px; }
  h2 { font:400 clamp(54px, 6vw, 92px)/.92 'Instrument Serif', serif; letter-spacing:-.045em; margin:25px 0 0; }
  h2 em { color:var(--muted); font-weight:400; }
  .section-heading > p { justify-self:end; max-width:480px; margin:0; font-size:17px; line-height:1.65; color:var(--muted); }
  .cards { display:grid; grid-template-columns:repeat(2, 1fr); border-top:1px solid var(--ink); border-left:1px solid var(--line); }
  .indicator { position:relative; min-width:0; padding:34px; border-right:1px solid var(--line); border-bottom:1px solid var(--line); transition:background .25s ease; }
  .indicator:hover { background:rgba(255,255,255,.3); }
  .indicator.featured { grid-column:span 2; }
  .card-header { display:flex; justify-content:space-between; gap:20px; align-items:start; }
  .eyebrow { color:var(--muted); margin:0 0 14px; }
  h3 { font:400 34px 'Instrument Serif', serif; margin:0; }
  .status { flex:none; display:flex; align-items:center; gap:7px; border:1px solid var(--line); border-radius:20px; padding:7px 10px; font:500 9px 'DM Mono', monospace; letter-spacing:.1em; text-transform:uppercase; }
  .status i { width:7px; height:7px; background:var(--signal); border-radius:50%; }
  .metric-row { display:grid; grid-template-columns:1fr 180px; gap:40px; align-items:end; padding:38px 0 32px; }
  .metric-row strong { display:block; font:400 clamp(64px, 7vw, 106px)/.8 'Instrument Serif', serif; letter-spacing:-.055em; }
  .metric-row > div > span { display:block; margin-top:15px; color:var(--muted); font-size:12px; }
  .gauge-label { font:500 9px 'DM Mono', monospace !important; letter-spacing:.1em; color:var(--ink) !important; }
  .gauge-track { position:relative; height:3px; margin:14px 0 9px; background:linear-gradient(90deg,#718575 0 34%,#d7a329 64%,#ff4d2e); }
  .gauge-track i { position:absolute; top:50%; width:12px; height:12px; background:var(--paper); border:3px solid var(--signal); border-radius:50%; transform:translate(-50%,-50%); }
  .gauge-ends { color:var(--muted); font-size:7px; }
  .chart-wrap { border-top:1px solid var(--line); padding-top:18px; }
  .chart { display:block; width:100%; height:180px; overflow:visible; }
  .chart line { stroke:var(--line); stroke-width:.25; stroke-dasharray:1 2; }
  .chart polygon { fill:color-mix(in srgb, var(--signal) 11%, transparent); }
  .chart polyline { fill:none; stroke:var(--signal); stroke-width:.75; vector-effect:non-scaling-stroke; }
  .chart circle { fill:var(--signal); vector-effect:non-scaling-stroke; }
  .chart-years { display:flex; justify-content:space-between; color:var(--muted); font:400 8px 'DM Mono', monospace; letter-spacing:.09em; }
  .description { max-width:720px; margin:32px 0; color:#44473f; font-size:14px; line-height:1.7; }
  .card-footer { display:flex; justify-content:space-between; align-items:end; gap:20px; border-top:1px solid var(--line); padding-top:17px; font:500 9px 'DM Mono', monospace; letter-spacing:.06em; }
  .card-footer a { color:var(--muted); text-align:right; text-decoration:none; }
  .card-footer a:hover { color:var(--risk); }
  .as-of { position:absolute; right:8px; top:50%; transform:translateY(-50%) rotate(90deg); transform-origin:right center; color:var(--muted); font:400 7px 'DM Mono', monospace; letter-spacing:.1em; }
  .method { padding-block:130px; border-top:1px solid var(--ink); }
  .method > div { display:grid; grid-template-columns:1.1fr .9fr; gap:80px; align-items:end; }
  .method-copy { display:grid; grid-template-columns:1fr 1fr; gap:34px; color:var(--muted); line-height:1.7; }
  .method-copy p { margin:0; }
  footer { min-height:140px; border-top:1px solid var(--ink); display:grid; grid-template-columns:1fr 1fr 1fr; align-items:center; font:400 9px 'DM Mono', monospace; letter-spacing:.08em; }
  footer p { text-align:center; color:var(--muted); }
  footer > a:last-child { text-align:right; text-decoration:none; }
  @keyframes grow { from { transform:scaleX(0); } }
  @keyframes pulse { 50% { box-shadow:0 0 0 5px rgba(95,139,102,.12); } }
  @media (max-width:800px) {
    .wrap { width:min(100% - 32px, 1320px); }
    .site-header { height:65px; }
    .freshness { font-size:0; }
    .freshness::after { content:'UPDATED DAILY'; font-size:8px; }
    .hero { min-height:auto; grid-template-columns:1fr; gap:70px; padding:90px 0 110px; }
    h1 { font-size:46vw; margin:35px 0 50px -4px; }
    .hero-summary { font-size:20px; }
    .scroll-cue { display:none; }
    .evidence { padding-block:85px; }
    .section-heading,.method > div { grid-template-columns:1fr; gap:38px; }
    .section-heading > p { justify-self:start; }
    .cards { grid-template-columns:1fr; }
    .indicator.featured { grid-column:auto; }
    .indicator { padding:25px 20px 30px; }
    .metric-row { grid-template-columns:1fr; gap:28px; }
    .gauge { max-width:220px; }
    .chart { height:130px; }
    .method { padding-block:85px; }
    .method-copy { grid-template-columns:1fr; }
    footer { grid-template-columns:1fr; gap:22px; padding-block:38px; }
    footer p,footer > a:last-child { text-align:left; margin:0; }
  }
  @media (prefers-reduced-motion:reduce) { * { animation:none !important; scroll-behavior:auto !important; } }
</style>
