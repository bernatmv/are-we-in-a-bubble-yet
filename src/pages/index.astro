---
import data from '../data/indicators.json';
import { copy, indicatorCopy, localeMeta, statusCopy, uiCopy, type Locale } from '../i18n';
import { articlePath, articles } from '../articles';
import Analytics from '../components/Analytics.astro';
import BrandMark from '../components/BrandMark.astro';
import ConfidenceGauge from '../components/ConfidenceGauge.astro';
import FontFaces from '../components/FontFaces.astro';
import LanguageSelector from '../components/LanguageSelector.astro';
import SpeedGauge from '../components/SpeedGauge.astro';

interface Props { locale?: Locale }

const locale = Astro.props.locale ?? 'en';
const c = copy[locale];
const ui = uiCopy[locale];
const site = 'https://areweinabubleyet.com';
const canonical = new URL(c.path, site).href;

const colors = { Extreme: '#ff4d2e', Elevated: '#d7a329', Complacent: '#df7b17', Neutral: '#526656' };

const chartScales = {
  cape: { min: 0, mid: 25, max: 50 },
  buffett: { min: 0, mid: 125, max: 250 },
  margin: { min: 0, mid: 800000, max: 1600000 },
  allocation: { min: 0, mid: 25, max: 50 },
  credit: { min: 0, mid: 3, max: 6 },
  vix: { min: 0, mid: 30, max: 60 }
} as const;

function formatChartValue(id: string, value: number) {
  const decimal = (places = 1) => new Intl.NumberFormat(localeMeta[locale].intl, {
    minimumFractionDigits: places,
    maximumFractionDigits: places
  }).format(value);
  if (id === 'cape') return `${decimal()}×`;
  if (id === 'margin') return value === 0 ? '$0' : `$${decimal()}T`;
  if (['buffett', 'allocation', 'credit'].includes(id)) return `${decimal(value % 1 ? 1 : 0)}%`;
  return decimal(value % 1 ? 1 : 0);
}

function formatHistoryDate(time: number) {
  const year = Math.floor(time);
  const month = Math.min(11, Math.max(0, Math.round((time - year) * 12)));
  return new Intl.DateTimeFormat(localeMeta[locale].intl, { month: 'short', year: 'numeric', timeZone: 'UTC' })
    .format(new Date(Date.UTC(year, month, 1)));
}

function chartGeometry(history: readonly (readonly number[])[], scale: { min: number; mid: number; max: number }) {
  const values = history.map((point) => Number(point[1]));
  const times = history.map((point) => Number(point[0]));
  const start = Math.min(...times);
  const end = Math.max(...times);
  const points = values.map((value, index) => {
    const x = ((times[index] - start) / Math.max(end - start, 1)) * 100;
    const y = 36 - ((value - scale.min) / Math.max(scale.max - scale.min, 1)) * 30;
    return { x, y, value, time: times[index] };
  });
  let line = `M ${points[0].x.toFixed(2)} ${points[0].y.toFixed(2)}`;
  for (let index = 0; index < points.length - 1; index++) {
    const previous = points[Math.max(0, index - 1)];
    const current = points[index];
    const next = points[index + 1];
    const after = points[Math.min(points.length - 1, index + 2)];
    const control1 = { x: current.x + (next.x - previous.x) / 6, y: current.y + (next.y - previous.y) / 6 };
    const control2 = { x: next.x - (after.x - current.x) / 6, y: next.y - (after.y - current.y) / 6 };
    line += ` C ${control1.x.toFixed(2)} ${control1.y.toFixed(2)}, ${control2.x.toFixed(2)} ${control2.y.toFixed(2)}, ${next.x.toFixed(2)} ${next.y.toFixed(2)}`;
  }
  return { line, area: `${line} L 100 36 L 0 36 Z`, points, last: points.at(-1), start, end };
}

const updated = new Intl.DateTimeFormat(localeMeta[locale].intl, { dateStyle: 'medium', timeZone: 'UTC' }).format(new Date(data.updatedAt));
const elevatedCount = data.indicators.filter((item) => item.score >= 60).length;
const marketEvents = [2000.19, 2008.70, 2020.21, 2022.45].map((time, index) => ({ time, year: Math.floor(time), label: ui.events[index] }));
const englishSignalNames = {
  cape: 'Shiller CAPE',
  margin: 'Margin debt',
  credit: 'Corporate credit spread',
  allocation: 'Household equity allocation'
} as const;

function localizedIndicator(indicator: typeof data.indicators[number]) {
  if (locale === 'en') return indicator;
  const translations = indicatorCopy[locale as Exclude<Locale, 'en'>];
  const translated = translations[indicator.id as keyof typeof translations];
  let change: string = translated.change;
  if (change === 'VARIACIÓN_INTERANUAL' || change === 'YOY') {
    change = `${indicator.change.match(/[+−-]?\d+(?:\.\d+)?%/)?.[0] ?? ''} ${ui.yoy}`;
  }
  let asOf = indicator.asOf;
  const monthly = asOf.match(/^(\w{3}) (\d{4})$/);
  if (monthly) asOf = new Intl.DateTimeFormat(localeMeta[locale].intl, { month: 'short', year: 'numeric', timeZone: 'UTC' }).format(new Date(`${monthly[1]} 1, ${monthly[2]} UTC`));
  const quarterly = asOf.match(/^Q(\d) (\d{4})$/);
  if (quarterly) asOf = locale === 'ja' ? `${quarterly[2]}年第${quarterly[1]}四半期` : `${['es', 'ca'].includes(locale) ? 'T' : 'Q'}${quarterly[1]} ${quarterly[2]}`;
  const displayValue = ['es', 'ca', 'de', 'fr', 'it'].includes(locale) ? indicator.displayValue.replace('.', ',') : indicator.displayValue;
  const name = englishSignalNames[indicator.id as keyof typeof englishSignalNames] ?? translated.name;
  return { ...indicator, ...translated, name, change, asOf, displayValue };
}

const rankedIndicators = [...data.indicators].sort((a, b) => b.score - a.score).map(localizedIndicator);
const orderedIndicators = [...data.indicators].sort((a, b) => {
  const weight = (eyebrow: string) => Number(eyebrow.match(/\d+/)?.[0] ?? 0);
  return weight(b.eyebrow) - weight(a.eyebrow);
});
const leadingNames = rankedIndicators.slice(0, 2).map((item) => item.name);
const nameList = `${leadingNames[0]} ${ui.and} ${leadingNames[1]}`;
const heroDetail = elevatedCount >= 4
  ? ui.broad(elevatedCount, data.indicators.length, nameList)
  : elevatedCount >= 2
    ? ui.concentrated(nameList, data.indicators.length - elevatedCount)
    : ui.contained(leadingNames[0]);
const confidenceKey = data.confidence >= 75 ? 'high' : data.confidence >= 50 ? 'medium' : 'low';
const confidenceTier = confidenceKey === 'high' ? c.confidenceHigh : confidenceKey === 'medium' ? c.confidenceMedium : c.confidenceLow;

const schema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebSite', '@id': `${site}/#website`, url: `${site}/`, name: 'Are We in a Bubble Yet?',
      description: c.description, inLanguage: Object.keys(localeMeta)
    },
    {
      '@type': 'WebPage', '@id': `${canonical}#webpage`, url: canonical, name: c.title, description: c.description,
      isPartOf: { '@id': `${site}/#website` }, inLanguage: c.lang, dateModified: data.updatedAt,
      primaryImageOfPage: { '@type': 'ImageObject', url: `${site}${c.image}`, width: 1200, height: 630 },
      about: { '@type': 'FinancialProduct', name: c.aboutTitle }
    },
    {
      '@type': 'Dataset', '@id': `${canonical}#dataset`, name: c.datasetName, description: c.datasetDescription,
      url: canonical, creator: { '@type': 'Organization', name: 'Are We in a Bubble Yet?', url: `${site}/` },
      dateModified: data.updatedAt, inLanguage: c.lang, temporalCoverage: '1871/..',
      variableMeasured: data.indicators.map((item) => localizedIndicator(item).name),
      isBasedOn: data.indicators.map((item) => item.sourceUrl)
    }
  ]
};
---

<!doctype html>
<html lang={c.lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <FontFaces />
    <meta name="description" content={c.description} />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
    <meta name="theme-color" content="#f0eee7" />
    <meta name="application-name" content="Are We in a Bubble Yet?" />
    <link rel="canonical" href={canonical} />
    {Object.entries(localeMeta).map(([code, item]) => <link rel="alternate" hreflang={code} href={new URL(item.path, site).href} />)}
    <link rel="alternate" hreflang="x-default" href={`${site}/`} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon-32.png" type="image/png" sizes="32x32" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" sizes="180x180" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="alternate" type="application/rss+xml" title="Are We in a Bubble Yet?" href="/feed.xml" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Are We in a Bubble Yet?" />
    <meta property="og:title" content={c.title} />
    <meta property="og:description" content={c.description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content={c.locale} />
    {Object.entries(localeMeta).filter(([code]) => code !== locale).map(([, item]) => <meta property="og:locale:alternate" content={item.og} />)}
    <meta property="og:image" content={`${site}${c.image}`} />
    <meta property="og:image:secure_url" content={`${site}${c.image}`} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={c.imageAlt} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={c.title} />
    <meta name="twitter:description" content={c.description} />
    <meta name="twitter:image" content={`${site}${c.image}`} />
    <meta name="twitter:image:alt" content={c.imageAlt} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />
    <Analytics />
    <title>{c.title}</title>
  </head>
  <body>
    <header class="site-header wrap">
      <a class="wordmark" href={c.path} aria-label={c.homeLabel}>
        <BrandMark />
        {c.wordmark}
      </a>
      <div class="header-meta">
        <div class="freshness"><span></span> {c.freshness} · {updated.toUpperCase()}</div>
        <LanguageSelector locale={locale} />
      </div>
    </header>

    <main>
      <section class="hero wrap" aria-labelledby="verdict-title" data-score={data.score}>
        <div class="hero-copy">
          <h1 id="verdict-title" class:list={[data.verdict === 'MAYBE' && 'medium', !['YES', 'NO', 'MAYBE'].includes(data.verdict) && 'long']}>{c.verdict[data.verdict as keyof typeof c.verdict]}<i>.</i></h1>
          <p class="hero-summary">{c.summaries[data.verdict as keyof typeof c.summaries]}</p>
          <p class="hero-detail">{heroDetail}</p>
        </div>
        <div class="score-panel" aria-label={`${c.scoreAria}: ${data.score} / 100`}>
          <div class="score-top">
            <span>{c.scoreLabel}</span>
            <span>{data.score} / 100</span>
          </div>
          <div class="score-track"><span style={`width:${data.score}%`}></span></div>
          <div class="score-labels"><span>{c.cool}</span><span>{c.stretched}</span><span>{c.bubble}</span></div>
          <p>{ui.elevated(elevatedCount, data.indicators.length)} {c.scoreCopy}</p>
          <ConfidenceGauge score={data.confidence} label={c.confidenceLabel} tier={confidenceTier} help={c.confidenceHelp} detail={c.confidenceCopy[confidenceKey]} />
          <nav class="signal-dials" aria-label={ui.jump}>
            {orderedIndicators.map((rawIndicator) => {
              const indicator = localizedIndicator(rawIndicator);
              return (
                <a href={`#signal-${indicator.id}`} aria-label={`${indicator.name}: ${indicator.score} / 100`}>
                  <SpeedGauge id={`summary-${indicator.id}`} score={indicator.score} label={c.risk} name={indicator.name} compact />
                </a>
              );
            })}
          </nav>
        </div>
        <a class="scroll-cue" href="#evidence-title">↓ <span>{c.readEvidence}</span></a>
      </section>

      <section class="evidence wrap" aria-labelledby="evidence-title">
        <div class="section-heading">
          <div>
            <p class="kicker">{c.evidenceKicker}</p>
            <h2 id="evidence-title">{c.evidenceTitle[0]}<br /><em>{c.evidenceTitle[1]}</em></h2>
          </div>
          <p>{c.evidenceIntro}</p>
        </div>

        <div class="cards">
          {orderedIndicators.map((rawIndicator, index) => {
            const indicator = localizedIndicator(rawIndicator);
            const scale = chartScales[indicator.id as keyof typeof chartScales];
            const chart = chartGeometry(indicator.history, scale);
            const visibleEvents = marketEvents.filter((event) => event.time >= chart.start && chart.end >= event.time)
              .map((event) => ({ ...event, position: ((event.time - chart.start) / Math.max(chart.end - chart.start, 1)) * 100 }));
            const category = indicator.eyebrow.split('·')[0].trim();
            const weight = indicator.eyebrow.match(/\d+%/)?.[0];
            const inspectionPoints = chart.points.map((point) => ({
              x: point.x,
              y: point.y,
              value: formatChartValue(indicator.id, indicator.id === 'margin' ? point.value / 1000000 : point.value),
              date: formatHistoryDate(point.time)
            }));
            return (
            <article id={`signal-${indicator.id}`} class:list={['indicator', index === 0 && 'featured']} style={`--signal:${colors[rawIndicator.status as keyof typeof colors] ?? '#526656'}`}>
              <div class="card-header">
                <div>
                  <p class="eyebrow">{String(index + 1).padStart(2, '0')} / {category}</p>
                  <h3>{indicator.name}</h3>
                  {indicator.id === 'buffett' && <span class="buffett-note">{ui.buffett}</span>}
                </div>
                <div class="card-meta">
                  <span class="weight"><span class="weight-value">{weight}</span><small>{ui.weight}</small></span>
                  <span class="status"><i></i>{statusCopy[locale][rawIndicator.status as keyof typeof statusCopy.en]}</span>
                </div>
              </div>

              <div class="metric-row">
                <div>
                  <strong>{indicator.displayValue}</strong>
                  <span>{indicator.change}</span>
                </div>
                <SpeedGauge id={`card-${indicator.id}`} score={indicator.score} label={c.risk} />
              </div>

              <div class="chart-wrap">
                <div
                  class="chart-plot"
                  tabindex="0"
                  aria-label={`${indicator.name} historical trend. Use arrow keys to inspect values.`}
                  data-points={JSON.stringify(inspectionPoints)}
                >
                  <div class="chart-canvas">
                  <svg class="chart" viewBox="0 0 100 40" preserveAspectRatio="none" role="img" aria-label={`${indicator.name} historical trend`}>
                    <defs>
                      <pattern id={`dither-${indicator.id}`} width="1" height="1.8" patternUnits="userSpaceOnUse">
                        <rect x=".12" y=".16" width=".16" height=".29" rx=".03" fill="var(--signal)" />
                        <rect x=".64" y="1.02" width=".13" height=".24" rx=".025" fill="var(--signal)" />
                      </pattern>
                    </defs>
                    <line x1="0" y1="36" x2="100" y2="36" />
                    <line x1="0" y1="21" x2="100" y2="21" />
                    <line x1="0" y1="6" x2="100" y2="6" />
                    <path class="chart-area" d={chart.area} fill={`url(#dither-${indicator.id})`} />
                    <path class="chart-line" d={chart.line} />
                    <line class="current-point" x1={chart.last?.x} x2={chart.last?.x} y1={chart.last?.y} y2={(chart.last?.y ?? 0) + .001} />
                  </svg>
                  <div class="event-layer" aria-hidden="true">
                    {visibleEvents.map((event) => (
                      <span class="market-event" style={`left:${event.position}%`}>
                        <b>{event.year}</b><em>{event.label}</em>
                      </span>
                    ))}
                  </div>
                  <div class="chart-crosshair" aria-hidden="true"></div>
                  <output class="chart-tooltip" aria-live="polite"><b></b><span></span></output>
                  </div>
                  <div class="y-axis" aria-hidden="true">
                    <span>{formatChartValue(indicator.id, indicator.id === 'margin' ? scale.max / 1000000 : scale.max)}</span>
                    <span>{formatChartValue(indicator.id, indicator.id === 'margin' ? scale.mid / 1000000 : scale.mid)}</span>
                    <span>{formatChartValue(indicator.id, indicator.id === 'margin' ? scale.min / 1000000 : scale.min)}</span>
                  </div>
                </div>
                <div class="chart-years"><span>{Math.floor(chart.start)}</span><span>{c.trend}</span><span>{Math.floor(chart.end)}</span></div>
              </div>

              <p class="description">{indicator.description}</p>
              <div class="card-footer">
                <span>{indicator.threshold}</span>
                <a href={indicator.sourceUrl} target="_blank" rel="noreferrer">{indicator.source} ↗</a>
              </div>
              <span class="as-of">{c.asOf} {indicator.asOf.toUpperCase()}</span>
            </article>
          )})}
        </div>
      </section>

      <section class="method wrap" aria-labelledby="method-title">
        <p class="kicker">{c.methodKicker}</p>
        <div>
          <h2 id="method-title">{c.methodTitle[0]}<br /><em>{c.methodTitle[1]}</em></h2>
          <div class="method-copy">
            <p>{c.methodP1}</p>
            <p>{c.methodP2}</p>
          </div>
        </div>
      </section>

      <section class="about wrap" aria-labelledby="about-title">
        <p class="kicker">{c.aboutKicker}</p>
        <div>
          <h2 id="about-title">{c.aboutTitle}<br /><em>{c.aboutVerdict[data.verdict as keyof typeof c.aboutVerdict]}</em></h2>
          <div class="about-copy">
            <p>{c.aboutP1}</p>
            <p>{c.aboutP2}</p>
          </div>
        </div>
      </section>
    </main>

    <footer class="wrap">
      <div class="footer-brand">
        <a class="wordmark" href={c.path}><BrandMark /> {c.wordmark}</a>
        <p>{c.disclaimer}</p>
      </div>
      <nav class="footer-reading" aria-label={c.explore}>
        <span>{c.explore}</span>
        {articles.map((article, index) => <a href={articlePath(article, locale)}>{c.articleTitles[index]} <i>→</i></a>)}
      </nav>
      <div class="footer-meta">
        <a href="#method-title">{c.methodology} ↑</a>
        <span>© {new Date().getUTCFullYear()} · {c.freshness}</span>
      </div>
    </footer>
    <script>
      type InspectionPoint = { x: number; y: number; value: string; date: string };

      document.querySelectorAll<HTMLElement>('.chart-plot[data-points]').forEach((plot) => {
        const canvas = plot.querySelector<HTMLElement>('.chart-canvas');
        const crosshair = plot.querySelector<HTMLElement>('.chart-crosshair');
        const tooltip = plot.querySelector<HTMLOutputElement>('.chart-tooltip');
        const tooltipValue = tooltip?.querySelector<HTMLElement>('b');
        const tooltipDate = tooltip?.querySelector<HTMLElement>('span');
        const points = JSON.parse(plot.dataset.points ?? '[]') as InspectionPoint[];
        let activeIndex = Math.max(0, points.length - 1);

        if (!canvas || !crosshair || !tooltip || !tooltipValue || !tooltipDate || points.length === 0) return;

        const showPoint = (index: number) => {
          activeIndex = Math.max(0, Math.min(points.length - 1, index));
          const point = points[activeIndex];
          const top = (point.y / 40) * 100;
          plot.classList.add('inspecting');
          crosshair.style.left = `${point.x}%`;
          crosshair.style.setProperty('--point-y', `${Math.max(0, Math.min(100, ((point.y - 6) / 30) * 100))}%`);
          tooltip.style.left = `${point.x}%`;
          tooltip.style.top = `${top}%`;
          tooltip.classList.toggle('align-right', point.x > 72);
          tooltipValue.textContent = point.value;
          tooltipDate.textContent = point.date;
        };

        const inspectPointer = (event: PointerEvent) => {
          const bounds = canvas.getBoundingClientRect();
          const x = Math.max(0, Math.min(1, (event.clientX - bounds.left) / bounds.width)) * 100;
          let nearest = 0;
          for (let index = 1; index < points.length; index++) {
            if (Math.abs(points[index].x - x) < Math.abs(points[nearest].x - x)) nearest = index;
          }
          showPoint(nearest);
        };

        canvas.addEventListener('pointermove', inspectPointer);
        canvas.addEventListener('pointerdown', inspectPointer);
        canvas.addEventListener('pointerleave', () => {
          if (document.activeElement !== plot) plot.classList.remove('inspecting');
        });
        plot.addEventListener('focus', () => showPoint(activeIndex));
        plot.addEventListener('blur', () => plot.classList.remove('inspecting'));
        plot.addEventListener('keydown', (event) => {
          if (!['ArrowLeft', 'ArrowRight', 'Home', 'End', 'Escape'].includes(event.key)) return;
          event.preventDefault();
          if (event.key === 'Escape') return plot.classList.remove('inspecting');
          if (event.key === 'Home') return showPoint(0);
          if (event.key === 'End') return showPoint(points.length - 1);
          showPoint(activeIndex + (event.key === 'ArrowRight' ? 1 : -1));
        });
      });
    </script>
  </body>
</html>

<style is:global>
  :root { --paper:#f0eee7; --ink:#151711; --muted:#686b62; --line:#c9c7bd; --risk:#ff4d2e; --risk-text:#bf3520; --green:#526656; }
  * { box-sizing:border-box; }
  html { scroll-behavior:smooth; }
  body { margin:0; overflow-x:clip; color:var(--ink); background:var(--paper); font-family:'Manrope', sans-serif; font-size:15px; }
  body::before { content:''; position:fixed; inset:0; pointer-events:none; opacity:.26; background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 180 180' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='.9' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='.18'/%3E%3C/svg%3E"); z-index:10; mix-blend-mode:multiply; }
  a { color:inherit; }
  .wrap { width:min(1320px, calc(100% - 64px)); margin-inline:auto; }
  .site-header { height:78px; display:flex; align-items:center; justify-content:space-between; border-bottom:1px solid var(--line); }
  .wordmark { display:flex; align-items:center; gap:11px; font-family:'DM Mono', monospace; font-size:12px; font-weight:500; letter-spacing:.08em; text-decoration:none; }
  .header-meta { display:flex; align-items:center; gap:22px; }
  .freshness { display:flex; align-items:center; gap:9px; font-family:'DM Mono', monospace; font-size:10px; letter-spacing:.1em; color:var(--muted); }
  .freshness span { width:6px; height:6px; background:#5f8b66; border-radius:50%; animation:pulse 2.5s infinite; }
  .hero { min-height:calc(100vh - 78px); position:relative; display:grid; grid-template-columns:1.35fr .65fr; gap:9vw; align-items:center; padding-block:80px 110px; }
  .hero-copy,.score-panel { min-width:0; }
  .kicker,.eyebrow { font-family:'DM Mono', monospace; font-size:10px; letter-spacing:.15em; font-weight:500; }
  .kicker::before { content:'— '; color:var(--risk); }
  h1 { font-family:'Instrument Serif', serif; font-size:clamp(150px, 24vw, 360px); font-weight:400; line-height:.68; letter-spacing:-.07em; margin:34px 0 54px -12px; }
  h1.medium { font-size:clamp(110px,20vw,300px); }
  h1.long { max-width:100%; font-size:clamp(46px,10.5vw,150px); line-height:.78; letter-spacing:-.055em; white-space:nowrap; }
  h1 i { color:var(--risk); font-style:normal; }
  .hero-summary { max-width:610px; margin:0; font-size:clamp(20px, 2vw, 29px); line-height:1.42; letter-spacing:-.035em; }
